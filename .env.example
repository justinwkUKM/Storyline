# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# FIREBASE_PROJECT_ID: Firebase project that contains the Firestore database.
FIREBASE_PROJECT_ID="your-firebase-project-id"

# FIREBASE_SERVICE_ACCOUNT_BASE64: Base64-encoded Firebase service account JSON.
# Useful for local development or non-GCP hosts. Cloud Run production should prefer Application Default Credentials.
FIREBASE_SERVICE_ACCOUNT_BASE64="base64_encoded_service_account_json"

# Optional local alternative to FIREBASE_SERVICE_ACCOUNT_BASE64.
# FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Browser Firebase config. These are public client values used for Firebase Analytics.
VITE_FIREBASE_API_KEY="your_web_api_key"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-firebase-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="your_messaging_sender_id"
VITE_FIREBASE_APP_ID="your_web_app_id"
VITE_FIREBASE_MEASUREMENT_ID="your_measurement_id"

# SESSION_SECRET: Required to sign authentication cookies.
SESSION_SECRET="replace-with-a-long-random-secret"

# SHARE_TOKEN_SECRET: Optional separate secret for encrypting retrievable share-link tokens.
# If omitted, the app falls back to SESSION_SECRET.
SHARE_TOKEN_SECRET="replace-with-a-long-random-share-secret"

# PORT: Optional local server port. Defaults to 3000.
PORT="3000"

